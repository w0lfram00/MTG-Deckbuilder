model User {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  email        String        @unique
  password     String
  hashed_rt    String?
  role         Role          @default(USER)
  decks        Deck[]
}

model Session {
  id          String @id @default(uuid()) @db.Uuid
  userId      String
  accessToken String
}

enum Role {
  USER
  ADMIN
}